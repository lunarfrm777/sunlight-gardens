---
const { notes } = Astro.props;
---
<div id="garden"></div>

<script type="module" define:vars={{ notes }}>
  import * as d3 from "https://cdn.jsdelivr.net/npm/d3@7/+esm";

  const width = 900;
  const height = 600;

  const nodes = notes.map(n => ({
    id: n.slug,
    title: n.title,
  }));

  const svg = d3
    .select("#garden")
    .append("svg")
    .attr("width", width)
    .attr("height", height);

const simulation = d3
  .forceSimulation(nodes)
  .force("charge", d3.forceManyBody().strength(-150))
  .force("center", d3.forceCenter(width / 2, height / 2))
  .force("collide", d3.forceCollide(35));

  const circles = svg
    .selectAll("circle")
    .data(nodes)
    .enter()
    .append("circle")
    .attr("r", 25)
    .style("fill", "lightgreen")
    .style("cursor", "pointer")
    .on("click", (_, d) => {
      window.location.href = `/notes/${d.id}`;
    });

  const labels = svg
    .selectAll("text")
    .data(nodes)
    .enter()
    .append("text")
    .text(d => d.title)
    .style("font-size", "12px");

  simulation.on("tick", () => {
    circles
      .attr("cx", d => d.x)
      .attr("cy", d => d.y);

    labels
      .attr("x", d => d.x + 30)
      .attr("y", d => d.y);
  });
</script>