---

// <!-- [slug].astro       → single note page (HAS slug) -->
//  <!-- detail page (params required) -->
import { client, urlFor } from '../../lib/sanity'
import { toHTML } from '@portabletext/to-html'

const { slug } = Astro.params

const note = await client.fetch(`
  *[_type == "note" && slug.current == $slug][0]{
    title,
    content,
    coverImage,
    tags
  }
`, { slug })
---

<main class="note">
  {note.coverImage && (
    <img class="cover" src={urlFor(note.coverImage).url()} />
  )}

  <h1>{note.title}</h1>

  {note.tags && (
    <div class="tags">
      {note.tags.map(tag => <span>#{tag}</span>)}
    </div>
  )}

  <article set:html={toHTML(note.content)} />
</main>